# Заполните перед запуском Docker

SECRET_KEY=change-me-generate-a-random-secret-key

DB_PASSWORD=change-me-postgres-password

OPENROUTER_API_KEY=change-me

EMAIL_PROVIDER=smtp
EMAIL_ADMIN=your-email@example.com
SEND_USER_EMAIL_COPY=True

EMAIL_HOST_USER=your-email@yandex.ru
EMAIL_HOST_PASSWORD=your-yandex-app-password
DEFAULT_FROM_EMAIL=your-email@yandex.ru

RESEND_API_KEY=re_change-me

# Остальное (менять не обязательно)

# Django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
DB_NAME=presentation-api
DB_USER=postgres
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_USE_SSL=False

# Rate limiting
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# OpenRouter AI
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_TIMEOUT_SECONDS=15

# Yandex SMTP
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False

# Resend (EMAIL_PROVIDER=resend)
# DEFAULT_FROM_EMAIL=AI Messages <onboarding@resend.dev>
# SEND_USER_EMAIL_COPY=False

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

